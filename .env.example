# ANOTE Web — Environment Variables
# Copy this file to .env.local and fill in the values.

# ──────────────────────────────────
# Contact Form (API route)
# ──────────────────────────────────
# Email address that receives contact form submissions
CONTACT_EMAIL_TO=info@anote.cz

# SMTP settings (for future email sending)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ──────────────────────────────────
# Analytics — Plausible
# ──────────────────────────────────
# Your site domain registered in Plausible
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=anote.cz

# Plausible host (optional — defaults to https://plausible.io)
# Set this if you are self-hosting Plausible
# NEXT_PUBLIC_PLAUSIBLE_HOST=https://plausible.io
