# ANOTE Web — Environment Variables
# Copy this file to .env.local and fill in the values.

# ──────────────────────────────────
# Contact Form (API route)
# ──────────────────────────────────
# Email address that receives contact form submissions
CONTACT_EMAIL_TO=anote-appka@outlook.com

# Admin dashboard password (used at /admin to view form submissions)
ADMIN_SECRET=changeme

# SMTP settings (for future email sending)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ──────────────────────────────────
# Analytics — Plausible
# ──────────────────────────────────
# Your site domain registered in Plausible
# TODO: replace with production domain when anote.cz is configured
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=yellow-forest-086a45303.7.azurestaticapps.net

# Plausible host (optional — defaults to https://plausible.io)
# Set this if you are self-hosting Plausible
# NEXT_PUBLIC_PLAUSIBLE_HOST=https://plausible.io
